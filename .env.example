APP_ENV=dev
LOG_LEVEL=INFO

# OpenAI models (requested: GPT-5 + GPT-5.3-codex)
LLM_PROVIDER=openai
LLM_MODEL_AGENT=gpt-5.3-codex
LLM_MODEL_SYNTHESIS=gpt-5
LLM_AGENT_MAX_OUTPUT_TOKENS=8192
LLM_SYNTHESIS_MAX_OUTPUT_TOKENS=8192
OPENAI_API_KEY=
# OPENAI_BASE_URL=

REQUEST_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.5

# Source resolver (git + archive + caching)
RESOLVER_CACHE_DIR=~/.cache/techflow-dev-team-simulator/sources
RESOLVER_DOWNLOAD_TIMEOUT_SECONDS=45
RESOLVER_MAX_DOWNLOAD_BYTES=25000000
RESOLVER_MAX_EXTRACT_BYTES=50000000
RESOLVER_MAX_EXTRACT_FILES=2000

# Optional fallback (for offline UI smoke tests only)
MOCK_LLM=false
